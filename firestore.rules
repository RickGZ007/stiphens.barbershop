rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Funcao auxiliar
    function isAdmin() {
      return request.auth != null;
    }

    // Leitura publica limitada por tamanho de resposta
    // Escrita apenas para admin autenticado
    match /hero/main {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /about/main {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /contact/main {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
      // Impede criacao de documentos gigantes
      allow create: if isAdmin() && request.resource.data.keys().size() <= 10;
      allow update: if isAdmin() && request.resource.data.keys().size() <= 10;
    }

    match /prices/{priceId} {
      allow read: if true;
      allow write: if isAdmin();
      allow create: if isAdmin() && request.resource.data.keys().size() <= 10;
      allow update: if isAdmin() && request.resource.data.keys().size() <= 10;
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Bloqueia TUDO que nao esta listado acima
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
